{
  "name": "ai2nao",
  "version": "0.1.0",
  "description": "Local-first indexer for git repos and manifest files (README, package.json, …) with SQLite + FTS",
  "type": "module",
  "bin": {
    "ai2nao": "./dist/cli.js"
  },
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc",
    "build:web": "vite build --config web/vite.config.ts",
    "dev": "tsx src/cli.ts",
    "dev:api": "tsx src/cli.ts serve --port 8787",
    "dev:web": "vite --config web/vite.config.ts --port 5173",
    "dev:ui": "concurrently -k \"npm run dev:api\" \"npm run dev:web\"",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "git",
    "indexer",
    "sqlite",
    "fts",
    "local-first"
  ],
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@tanstack/react-query": "^5.96.2",
    "better-sqlite3": "^11.7.0",
    "commander": "^12.1.0",
    "date-fns": "^4.1.0",
    "hono": "^4.12.11",
    "prism-react-renderer": "^2.4.1",
    "prismjs": "^1.30.0",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.10.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0"
  }
}
